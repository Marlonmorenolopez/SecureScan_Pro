# ===========================================
# SecureScan Pro - Variables de Entorno v3.0
# ===========================================
# Copia este archivo a .env y ajusta los valores
# Compatible con: SecureScanOrchestrator v3.0 (Resiliente)

# ===========================================
# CONFIGURACIÓN DEL SERVIDOR
# ===========================================

# Puerto del servidor API REST
PORT=4000

# Entorno: development, production, test
NODE_ENV=production

# ===========================================
# TIMEOUTS DE HERRAMIENTAS (segundos)
# Alineados con Orchestrator v3.0
# ===========================================

# WhatWeb - Detección de tecnologías
WHATWEB_TIMEOUT=60
WHATWEB_AGGRESSION=3

# Nmap - Escaneo de puertos y servicios
NMAP_TIMEOUT=600
NMAP_TIMING=T4
NMAP_VERSION_INTENSITY=7
NMAP_SCRIPTS=vuln,vulners,safe

# Gobuster - Fuerza bruta de directorios
GOBUSTER_TIMEOUT=300
GOBUSTER_THREADS=50
GOBUSTER_MODES=dir,dns

# ZAP - Escaneo DAST
ZAP_TIMEOUT=1800
ZAP_SPIDER_TYPE=spiderClient
ZAP_SPIDER_MAX_DURATION=15
ZAP_ACTIVE_SCAN_ENABLED=true
ZAP_ACTIVE_SCAN_POLICY=Default
ZAP_ACTIVE_SCAN_MAX_DURATION=30

# ExploitDB - Búsqueda de exploits
EXPLOITDB_TIMEOUT=120
EXPLOITDB_MAX_RESULTS=10
EXPLOITDB_ENRICH_NVD=true
EXPLOITDB_EXCLUDE_TERMS=dos

# Metasploit - Explotación controlada (opcional)
METASPLOIT_ENABLED=false
METASPLOIT_TIMEOUT=600
METASPLOIT_DRY_RUN=true
METASPLOIT_MIN_RANKING=good
METASPLOIT_MAX_SESSIONS=3

# ===========================================
# CONFIGURACIÓN OWASP ZAP
# ===========================================

# API Key de ZAP (generar en: Tools > Options > API)
ZAP_API_KEY=changeme
ZAP_HOST=localhost
ZAP_PORT=8080
ZAP_DAEMON=true

# ===========================================
# WHITELIST DE TARGETS PERMITIDOS
# Alineado con allowedTargets del Orchestrator
# ===========================================

# Targets permitidos (separar con comas)
# NOTA: Solo estos targets son válidos para el orquestador v3.0
ALLOWED_TARGETS=localhost:3001,localhost:3002,localhost:3003,127.0.0.1:3001,127.0.0.1:3002,127.0.0.1:3003,172.20.0.0/24

# Red Docker interna (para contenedores lab)
DOCKER_NETWORK=172.20.0.0/24
DOCKER_GATEWAY=172.20.0.1

# ===========================================
# DIRECTORIOS DEL SISTEMA
# Estructura compatible con Orchestrator v3.0
# ===========================================

# Directorio base del proyecto
BASE_DIR=.

# Reportes finales
REPORTS_DIR=./reports

# Logs de ejecución
LOGS_DIR=./logs

# Archivos temporales de escaneo (por herramienta)
TEMP_DIR=./temp
TEMP_WHATWEB_DIR=./temp/whatweb
TEMP_NMAP_DIR=./temp/nmap
TEMP_GOBUSTER_DIR=./temp/gobuster
TEMP_ZAP_DIR=./temp/zap
TEMP_EXPLOITDB_DIR=./temp/exploitdb

# Salidas del backend
BACKEND_OUTPUTS_DIR=./backend/outputs

# ===========================================
# CONFIGURACIÓN DE WORDLISTS
# ===========================================

# Directorio de wordlists del sistema
WORDLISTS_SYSTEM_DIR=/usr/share/wordlists

# Wordlists específicas
WORDLIST_DIRB_COMMON=/usr/share/wordlists/dirb/common.txt
WORDLIST_SEC_LISTS=/usr/share/seclists/Discovery/Web-Content/common.txt
WORDLIST_DNS=/usr/share/seclists/Discovery/DNS/subdomains-top1million-5000.txt

# Fallback si no existen las anteriores
WORDLIST_FALLBACK=./wordlists/basic.txt

# Extensiones por defecto para Gobuster
GOBUSTER_EXTENSIONS=php,html,txt,bak,zip,sql,env,config,xml,json

# ===========================================
# LOGGING Y DEBUG
# ===========================================

# Nivel de logging: debug, info, warn, error
LOG_LEVEL=info

# Log específico del orquestador
SECURESCAN_LOG_LEVEL=info

# Modo debug verbose
DEBUG=false

# Colores en logs (true/false)
LOG_COLORS=true

# ===========================================
# CONFIGURACIÓN DEL LABORATORIO
# Solo 3 aplicaciones (v3.0 - eliminadas bWAPP, Hackazon, Mutillidae)
# ===========================================

# Juice Shop (OWASP Top 10 moderno)
LAB_JUICE_SHOP_PORT=3001
LAB_JUICE_SHOP_IMAGE=bkimminich/juice-shop:latest
LAB_JUICE_SHOP_CONTAINER=securescan-juice-shop

# DVWA (PHP clásico)
LAB_DVWA_PORT=3002
LAB_DVWA_IMAGE=vulnerables/web-dvwa:latest
LAB_DVWA_CONTAINER=securescan-dvwa

# WebGoat (Java tutoriales)
LAB_WEBGOAT_PORT=3003
LAB_WEBGOAT_IMAGE=webgoat/webgoat:latest
LAB_WEBGOAT_CONTAINER=securescan-webgoat

# Docker Compose
DOCKER_COMPOSE_FILE=./docker-compose.yml
DOCKER_NETWORK_NAME=securescan-lab

# ===========================================
# SEGURIDAD Y RATE LIMITING
# ===========================================

# Solo permitir escaneos desde localhost
LOCALHOST_ONLY=true

# Rate limiting: ventana de tiempo (ms)
RATE_LIMIT_WINDOW=60000

# Rate limiting: máximo de peticiones por ventana
RATE_LIMIT_MAX=100

# CORS - Orígenes permitidos (separar con comas)
CORS_ORIGINS=http://localhost:4000,http://127.0.0.1:4000

# ===========================================
# CONFIGURACIÓN DEL ORCHESTRATOR
# Componentes de resiliencia v3.0
# ===========================================

# Circuit Breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RESET_TIMEOUT=60000
CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=1

# File Stabilizer
FILE_STABILIZER_CHECK_INTERVAL=500
FILE_STABILIZER_MAX_ATTEMPTS=60
FILE_STABILIZER_STABILITY_ROUNDS=3
FILE_STABILIZER_TIMEOUT=30000

# Target Validator
TARGET_VALIDATOR_CONNECT_TIMEOUT=5000

# Process Manager
PROCESS_MANAGER_ENABLED=true
PROCESS_MANAGER_CLEANUP_TIMEOUT=5000
PROCESS_MANAGER_SIGKILL_DELAY=5000

# ===========================================
# LÍMITES DE ESCANEO
# ===========================================

# Máximo de escaneos concurrentes
MAX_CONCURRENT_SCANS=2

# Tiempo máximo total de escaneo (segundos)
MAX_SCAN_TIME=3600

# Máximo de fases fallidas antes de abortar (0 = infinito con failFast: false)
MAX_FAILED_PHASES=0

# ===========================================
# SCORING Y REPORTES
# ===========================================

# Versión CVSS a usar
CVSS_VERSION=3.1

# Usar EPSS (Exploit Prediction Scoring System)
USE_EPSS=true

# Calcular métricas temporales
CALCULATE_TEMPORAL=true

# Calcular métricas ambientales
CALCULATE_ENVIRONMENTAL=true

# Formatos de reporte disponibles (separar con comas)
REPORT_FORMATS=html,pdf,sarif,json

# Plantilla de reporte
REPORT_TEMPLATE=default

# Secciones del reporte (separar con comas)
REPORT_SECTIONS=executiveSummary,methodology,findings,riskAssessment,remediationPlan

# ===========================================
# INTEGRACIONES OPCIONALES
# ===========================================

# Webhook para notificaciones (opcional)
WEBHOOK_URL=
WEBHOOK_EVENTS=scan:complete,scan:error

# Integración con JIRA (opcional)
JIRA_ENABLED=false
JIRA_HOST=
JIRA_PROJECT=
JIRA_USERNAME=
JIRA_API_TOKEN=

# Integración con Slack (opcional)
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#security-alerts

# ===========================================
# NOTAS IMPORTANTES
# ===========================================
# 
# 1. Este archivo debe copiarse a .env y personalizarse
# 2. NUNCA commitear el archivo .env con credenciales reales
# 3. Los timeouts están alineados con el Orchestrator v3.0
# 4. ALLOWED_TARGETS debe coincidir con allowedTargets en orchestrator.js
# 5. Las herramientas eliminadas en v3.0 (nikto, wappalyzer) no tienen variables
#
# ===========================================